POSTGRES_PASSWORD=change_me_postgres_password

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_password
AIRFLOW_ADMIN_EMAIL=you@example.com
AIRFLOW_UID=50000

AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
PIPELINE_TIMEZONE=America/Sao_Paulo
S3_BUCKET=your_existing_s3_bucket
S3_ENDPOINT_URL=

RAW_PREFIX=raw
STATE_PREFIX=state
WAREHOUSE_PREFIX=warehouse
ARCHIVE_PREFIX=archive
PARQUET_BUCKET_COUNT=16

DBT_DUCKDB_PATH=/opt/airflow/duckdb/chess_pipeline.duckdb
DBT_DUCKDB_THREADS=4

CHESS_API_USER_AGENT=chess-data-platform/1.0 (contact: you@example.com)
CHESS_API_DELAY=0.5

ARCHIVE_REFRESH_DAYS=30
ACTIVE_ARCHIVE_REFRESH_HOURS=24
TITLE_TASK_MAX_WORKERS=3
STATE_SCAN_MAX_WORKERS=32
BACKFILL_PLAYERS_PER_RUN=10
BACKFILL_MONTHS_PER_PLAYER=6
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_SIZE=3
AIRFLOW__DATABASE__SQL_ALCHEMY_MAX_OVERFLOW=2
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_RECYCLE=1800
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_PRE_PING=true
AIRFLOW__CORE__PARALLELISM=2
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=2
AIRFLOW__CORE__DAGBAG_IMPORT_TIMEOUT=120
AIRFLOW__CORE__DAG_FILE_PROCESSOR_TIMEOUT=300
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=60
AIRFLOW__SCHEDULER__PARSING_PROCESSES=1
AIRFLOW__SCHEDULER__STALE_DAG_THRESHOLD=300
AIRFLOW__WEBSERVER__WORKERS=1

